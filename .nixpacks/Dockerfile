FROM ghcr.io/railwayapp/nixpacks:ubuntu-1745885067

ENTRYPOINT ["/bin/bash", "-l", "-c"]
WORKDIR /app/


COPY .nixpacks/nixpkgs-ffeebf0acf3ae8b29f8c7049cd911b9636efd7e7.nix .nixpacks/nixpkgs-ffeebf0acf3ae8b29f8c7049cd911b9636efd7e7.nix
RUN nix-env -if .nixpacks/nixpkgs-ffeebf0acf3ae8b29f8c7049cd911b9636efd7e7.nix && nix-collect-garbage -d


ARG ANTHROPIC_API_KEY BUILDKIT_DOCKERFILE_CHECK CI COMMAND_CENTER_PROCESS DEVELOPER_PATH INNGEST_DEV NEXT_PUBLIC_APP_NAME NEXT_PUBLIC_SUPABASE_ANON_KEY NEXT_PUBLIC_SUPABASE_URL NIXPACKS_METADATA NODE_ENV NPM_CONFIG_PRODUCTION PROJECT_BRANCHES_JSON PROJECT_REPOSITORIES_JSON RAILWAY_ENVIRONMENT RAILWAY_ENVIRONMENT_ID RAILWAY_ENVIRONMENT_NAME RAILWAY_PRIVATE_DOMAIN RAILWAY_PROJECT_ID RAILWAY_PROJECT_NAME RAILWAY_PUBLIC_DOMAIN RAILWAY_SERVICE_COMMAND_CENTER_RUNNER_URL RAILWAY_SERVICE_COMMAND_CENTER_URL RAILWAY_SERVICE_ID RAILWAY_SERVICE_NAME RAILWAY_STATIC_URL RAILWAY_VOLUME_ID RAILWAY_VOLUME_MOUNT_PATH RAILWAY_VOLUME_NAME SUPABASE_ACCESS_TOKEN SUPABASE_SERVICE_ROLE_KEY VERCEL_TOKEN WORKER_AGENT_ENGINE
ENV ANTHROPIC_API_KEY=$ANTHROPIC_API_KEY BUILDKIT_DOCKERFILE_CHECK=$BUILDKIT_DOCKERFILE_CHECK CI=$CI COMMAND_CENTER_PROCESS=$COMMAND_CENTER_PROCESS DEVELOPER_PATH=$DEVELOPER_PATH INNGEST_DEV=$INNGEST_DEV NEXT_PUBLIC_APP_NAME=$NEXT_PUBLIC_APP_NAME NEXT_PUBLIC_SUPABASE_ANON_KEY=$NEXT_PUBLIC_SUPABASE_ANON_KEY NEXT_PUBLIC_SUPABASE_URL=$NEXT_PUBLIC_SUPABASE_URL NIXPACKS_METADATA=$NIXPACKS_METADATA NODE_ENV=$NODE_ENV NPM_CONFIG_PRODUCTION=$NPM_CONFIG_PRODUCTION PROJECT_BRANCHES_JSON=$PROJECT_BRANCHES_JSON PROJECT_REPOSITORIES_JSON=$PROJECT_REPOSITORIES_JSON RAILWAY_ENVIRONMENT=$RAILWAY_ENVIRONMENT RAILWAY_ENVIRONMENT_ID=$RAILWAY_ENVIRONMENT_ID RAILWAY_ENVIRONMENT_NAME=$RAILWAY_ENVIRONMENT_NAME RAILWAY_PRIVATE_DOMAIN=$RAILWAY_PRIVATE_DOMAIN RAILWAY_PROJECT_ID=$RAILWAY_PROJECT_ID RAILWAY_PROJECT_NAME=$RAILWAY_PROJECT_NAME RAILWAY_PUBLIC_DOMAIN=$RAILWAY_PUBLIC_DOMAIN RAILWAY_SERVICE_COMMAND_CENTER_RUNNER_URL=$RAILWAY_SERVICE_COMMAND_CENTER_RUNNER_URL RAILWAY_SERVICE_COMMAND_CENTER_URL=$RAILWAY_SERVICE_COMMAND_CENTER_URL RAILWAY_SERVICE_ID=$RAILWAY_SERVICE_ID RAILWAY_SERVICE_NAME=$RAILWAY_SERVICE_NAME RAILWAY_STATIC_URL=$RAILWAY_STATIC_URL RAILWAY_VOLUME_ID=$RAILWAY_VOLUME_ID RAILWAY_VOLUME_MOUNT_PATH=$RAILWAY_VOLUME_MOUNT_PATH RAILWAY_VOLUME_NAME=$RAILWAY_VOLUME_NAME SUPABASE_ACCESS_TOKEN=$SUPABASE_ACCESS_TOKEN SUPABASE_SERVICE_ROLE_KEY=$SUPABASE_SERVICE_ROLE_KEY VERCEL_TOKEN=$VERCEL_TOKEN WORKER_AGENT_ENGINE=$WORKER_AGENT_ENGINE

# setup phase
# noop

# install phase
ENV NIXPACKS_PATH=/app/node_modules/.bin:$NIXPACKS_PATH
COPY . /app/.
RUN --mount=type=cache,id=s/8b06c162-7a46-4735-88f1-ac4103e6551f-/root/npm,target=/root/.npm npm ci

# build phase
COPY . /app/.
RUN --mount=type=cache,id=s/8b06c162-7a46-4735-88f1-ac4103e6551f-next/cache,target=/app/.next/cache --mount=type=cache,id=s/8b06c162-7a46-4735-88f1-ac4103e6551f-node_modules/cache,target=/app/node_modules/.cache npm run build


RUN printf '\nPATH=/app/node_modules/.bin:$PATH' >> /root/.profile


# start
COPY . /app

CMD ["node scripts/start-railway.js"]

